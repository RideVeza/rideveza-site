---
import HelpLayout from "../../../layouts/HelpLayout.astro";

// Guardian help articles. Ordered: get the app & get in, then using the app.
const articles = [
  {
    href: "/support/guardian/download-app",
    title: "Downloading the app",
    blurb: "Get the app on your phone, and what to check before you download.",
  },
  {
    href: "/support/guardian/create-account",
    title: "Creating your account",
    blurb: "Set up your account with the email your school has for you.",
  },
  {
    href: "/support/guardian/signing-in",
    title: "Signing in",
    blurb: "Sign in, and let your phone save your password.",
  },
  {
    href: "/support/guardian/live-map",
    title: "Tracking the bus",
    blurb: "Follow your child's bus, see when it will arrive and check each stop.",
  },
  {
    href: "/support/guardian/children",
    title: "Your children",
    blurb: "See each child's profile — school, care needs, equipment and contacts.",
  },
  {
    href: "/support/guardian/contacts",
    title: "Contacts",
    blurb: "Find phone numbers for your children's bus company and their schools.",
  },
  {
    href: "/support/guardian/account",
    title: "Account",
    blurb: "Update your details, change your password and log out.",
  },
  {
    href: "/support/guardian/reset-password",
    title: "Resetting your password",
    blurb: "Reset your password from the app or the sign-in screen.",
  },
  {
    href: "/support/guardian/glossary",
    title: "Icon glossary",
    blurb: "What each icon in the app means, from care needs to bus staff.",
  },
];
---

<HelpLayout
  title="Guardian Help"
  description="Help and training for the Veza Guardian App."
>
  <h1>Veza Guides and Support</h1>
  <span class="eyebrow">Veza Guardian App</span>
  <p class="subtitle">
    Short guides with pictures for the Veza Guardian App. Each one shows what a
    screen does and how to use it. Pick a topic below.
  </p>

  <ul class="card-list">
    {articles.map((a) => (
      <li>
        <a class="topic" href={a.href}>
          <div class="topic-body">
            <h2 class="topic-title">{a.title}</h2>
            <p class="topic-blurb">{a.blurb}</p>
          </div>
          <span class="topic-arrow" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ul>
</HelpLayout>

<style>
  /* Card appearance comes from the shared .topic styles in /veza-ui.css. */
  .card-list {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }
</style>
