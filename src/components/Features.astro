---
// Features section: centered eyebrow + heading, then three transparent cards.
// Each card (top→bottom): app screenshot → icon → title → description.
const cards = [
  {
    icon: "/images/icon-1.png",
    app: "/images/app-1.png",
    title: "Desktop App",
    desc: "Centralize control over routes, payroll, and trip adjustments with real-time updates for comprehensive management.",
  },
  {
    icon: "/images/icon-2.png",
    app: "/images/app-2.png",
    title: "Driver App",
    desc: "Empower drivers with essential trip details, navigation, and communication tools for safe and efficient journeys.",
  },
  {
    icon: "/images/icon-3.png",
    app: "/images/app-3.png",
    title: "Guardian App",
    desc: "Offer guardians real-time trip tracking, easy absence reporting, and profile updates for complete peace of mind.",
  },
];
---

<section class="features">
  <div class="features__bg"></div>
  <div class="features__wrap">
    <div class="features__head" data-reveal>
      <span class="features__pill">
        <span class="eyebrow">All-in-One Solution</span>
      </span>
      <h2 class="display features__title">
        Seamless management for dispatchers, drivers and guardians
      </h2>
    </div>

    <div class="features__grid">
      {
        cards.map((card, i) => (
          <article class="feature" data-reveal style={`transition-delay: ${i * 0.1}s`}>
            <div class="feature__image">
              <img
                src={card.app}
                alt={`${card.title} screenshot`}
                width="784"
                height="900"
                loading="lazy"
              />
            </div>

            <div class="feature__content">
              <img
                class="feature__icon"
                src={card.icon}
                alt=""
                width="112"
                height="112"
                loading="lazy"
                aria-hidden="true"
              />
              <div class="feature__text">
                <h3 class="card-title">{card.title}</h3>
                <p class="feature__desc">{card.desc}</p>
              </div>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>

<style>
  /* Section padding (live feat.card.container pad): 60 → 80 → 100 → 130.
     At ≥1440 live uses 130px top/bottom. */
  .features {
    position: relative;
    padding-top: 60px;
    padding-bottom: 60px;
    /* Gap between the features card and the CTA card below (live: 96px). */
    margin-bottom: 96px;
  }

  /* Gradient background card (live: a second "Hero Bg Shape" behind the
     features section — same gold/lavender gradient + inset + stepped radius). */
  .features__bg {
    position: absolute;
    inset-block: 0;
    left: 8px;
    right: 8px;
    background-image: linear-gradient(
      -47.0768deg,
      rgba(243, 172, 61, 0.1) -22.6935%,
      rgba(192, 169, 255, 0.2) 103.18%
    );
    border-radius: 30px;
    z-index: 0;
  }
  @media (min-width: 768px) {
    .features__bg { left: 16px; right: 16px; border-radius: 40px; }
  }
  @media (min-width: 1000px) {
    .features__bg { left: 20px; right: 20px; border-radius: 60px; }
  }
  @media (min-width: 1280px) {
    .features__bg { left: 25px; right: 25px; }
  }
  @media (min-width: 1440px) {
    .features__bg { left: 21px; right: 21px; border-radius: 96px; }
  }

  .features__wrap {
    position: relative;
    z-index: 1;
  }
  @media (min-width: 768px) {
    .features { padding-top: 80px; padding-bottom: 80px; }
  }
  @media (min-width: 1000px) {
    .features { padding-top: 100px; padding-bottom: 100px; }
  }
  @media (min-width: 1440px) {
    .features { padding-top: 130px; padding-bottom: 130px; margin-bottom: 120px; }
  }

  /* Wider than the 1200 site container so three 392px cards fit at ≥1440. */
  .features__wrap {
    width: 100%;
    max-width: 1284px; /* 1224 content + 2×30 gutter */
    margin-inline: auto;
    padding-inline: 20px;
  }
  @media (min-width: 768px) {
    .features__wrap { padding-inline: 30px; }
  }

  .features__head {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    margin-bottom: 117px; /* live 100px + 17px (Timothy: drop cards down) */
  }

  /* White pill around the eyebrow (same as hero: bg #fff, 6px 20px, radius 32). */
  .features__pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--white);
    border-radius: 32px;
    padding: 6px 20px;
  }

  /* Live feat.heading width steps: 708(768) / 964(1024) / 1000(1280) / 710(1440).
     At 1440 it narrows so the heading wraps to 3 lines (matching live). */
  .features__title {
    margin-top: 38px;
    max-width: 1000px;
  }
  @media (min-width: 1440px) {
    .features__title { max-width: 710px; }
  }

  /* Flex-wrap grid: 1 col → 2 col @768 → 3 col @1024.
     Widens to 1224 so three 392px cards fit at ≥1440 (3×392 + 2×24). */
  .features__grid {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 40px;
    max-width: 1224px;
    margin-inline: auto;
  }
  @media (min-width: 768px) {
    .features__grid { gap: 24px; }
  }
  @media (min-width: 1000px) {
    .features__grid { gap: 12px; }
  }
  @media (min-width: 1440px) {
    .features__grid { gap: 24px; }
  }

  .feature {
    display: flex;
    flex-direction: column;
    flex: 1 1 100%;
    max-width: 350px;
  }
  @media (min-width: 768px) {
    .feature { flex-basis: calc(50% - 12px); max-width: 340px; }
  }
  @media (min-width: 1000px) {
    .feature { flex-basis: 320px; max-width: 320px; }
  }
  @media (min-width: 1440px) {
    .feature { flex-basis: 392px; max-width: 392px; } /* image = 392 at 1440 */
  }

  /* Live image box: 320×379, object-fit contain (image centered in the box). */
  .feature__image {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 320 / 379;
  }
  .feature__image img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
    /* Hover zoom (live: card screenshots scale up on hover). */
    transition: transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .feature__image:hover img {
    transform: scale(1.05);
  }
  @media (prefers-reduced-motion: reduce) {
    .feature__image:hover img {
      transform: none;
    }
  }

  /* icon → title/desc, gap 32px. */
  .feature__content {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 32px;
    margin-top: 56px;
  }

  .feature__icon {
    width: 56px;
    height: 56px;
  }

  /* title → desc, gap 11px. Text caps at 360 even when the card (image) is
     wider — live: image 392 but text 360 at 1440. */
  .feature__text {
    display: flex;
    flex-direction: column;
    gap: 11px;
    max-width: 360px;
  }

  .feature__desc {
    font-size: 16px;
    font-weight: 400;
    line-height: 27.2px;
    letter-spacing: -0.3px;
    color: var(--slate);
    text-align: left;
  }
</style>
