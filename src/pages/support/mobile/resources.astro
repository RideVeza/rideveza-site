---
import HelpLayout from "../../../layouts/HelpLayout.astro";
---

<HelpLayout
  title="Resources"
  description="Open forms, documents and school calendars in the Veza Mobile App."
  back="/support/mobile"
>
  <h1>Resources</h1>

  <p class="overview">
    You can open Resources from the main navigation bar. This section provides
    quick access to important tools, reference materials and schedules to
    support your daily work.
  </p>

  <p>
    From here, you can open forms, review documents, and check school calendars
    to stay informed and prepared for your runs.
  </p>

  <!-- PLACEHOLDER: screenshots (Resources list + Forms screen) -->
  <div class="placeholder">Screenshots coming soon</div>
</HelpLayout>
