---
import HelpLayout from "../../../layouts/HelpLayout.astro";

// Callout items for the annotated screenshot (image to come).
const items = [
  "<strong>Change map provider</strong> — change your default map provider here. Veza supports both Apple and Google maps.",
];
---

<HelpLayout
  title="Account settings"
  description="Manage your profile in the Veza Mobile App."
  back="/support/mobile"
>
  <h1>Account settings</h1>

  <p class="overview">
    You can open the Account page from the main navigation bar. This screen
    shows your profile information, including your name, email, company and
    employee ID.
  </p>

  <p>
    From here, you can update your profile picture, choose your preferred
    navigation app, view the current app version, and securely log out of your
    account.
  </p>

  <!-- PLACEHOLDER: numbered screenshot + <Annotated items={items}> -->
  <div class="placeholder">Screenshots coming soon</div>
</HelpLayout>
