---
import HelpLayout from "../../../layouts/HelpLayout.astro";

// Requirements mirror the Veza Mobile App troubleshooting guide. Store links and
// screenshots are placeholders until the Veza Guardian listings are available.
---

<HelpLayout
  title="Downloading the app"
  description="Get the Veza Guardian App on your phone."
  back="/help/guardian"
>
  <h1>Downloading the app</h1>

  <p class="overview">
    The Veza Guardian App is free on the App Store and Google Play. A couple of
    quick checks make sure it installs the first time.
  </p>

  <section class="screen">
    <h2 class="screen__title">Before you download</h2>
    <ul class="reqs">
      <li>
        <strong>Free space</strong> — your phone needs at least 250 MB free to
        download the app.
      </li>
      <li>
        <strong>Set to Canada</strong> — the app is in the Canadian store, so
        your App Store or Google Play country must be set to Canada, or it won't
        show up.
      </li>
      <li>
        <strong>Signed in</strong> — you'll need to be signed in to your Apple
        Account on iPhone, or your Google Account on Android.
      </li>
    </ul>
  </section>

  <section class="screen">
    <h2 class="screen__title">Get the app</h2>
    <p class="screen__lead">
      Search for "Veza Guardian" in your phone's app store, or tap your store
      below.
    </p>
    <!-- PLACEHOLDER: replace with the App Store / Google Play screenshots + badges. -->
    <div class="placeholder">App Store &amp; Google Play — screenshots coming soon</div>
  </section>
</HelpLayout>
