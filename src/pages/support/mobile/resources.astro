---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const items = [
  "<strong><a href=\"/support/mobile/forms/\">Forms</a></strong> — fill in and submit your organization's forms, such as safety, student care and HR submissions.",
  "<strong><a href=\"/support/mobile/expenses-time-off/\">Time Off Request</a></strong> — request time off from your organization.",
  "<strong><a href=\"/support/mobile/expenses-time-off/\">Expense Reimbursement</a></strong> — submit an expense for reimbursement.",
  "<strong>School Calendars</strong> — check each school's calendar for holidays and closures.",
  "<strong>Documents</strong> — reference documents shared by your organization.",
  "<strong>Veza Resources</strong> — guides and help for using Veza.",
];
---

<HelpLayout
  title="Resources"
  description="Open forms, documents and school calendars in the Veza Mobile App."
  back="/support/mobile/"
  wide
>
  <h1>Resources</h1>

  <p class="overview">
    Open the <strong>Resources</strong> tab in the bottom navigation bar for
    quick access to the forms, documents and schedules that support your daily
    work.
  </p>

  <Annotated
    src="/images/support/mobile/resources/resources-annotated.png"
    alt="The Veza Mobile App Resources screen, with numbered callouts pointing to each section."
    ratio="2072 / 3664"
    items={items}
  />
</HelpLayout>
