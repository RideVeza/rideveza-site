---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const items = [
  "<strong>Transportation</strong> — your children's bus company. Tap to see its phone number.",
  "<strong>Schools</strong> — your children's schools. Tap to see a school's phone number.",
];
---

<HelpLayout
  title="Contacts"
  description="The phone numbers you might need in Veza Guardian."
  back="/support/guardian"
  wide
>
  <h1>Contacts</h1>

  <p class="overview">
    The <strong>Contacts</strong> tab keeps the phone numbers you might need in
    one place: your children's bus company and their schools.
  </p>

  <Annotated
    src="/images/support/guardian/contacts-annotated.png"
    alt="The Veza Guardian Contacts tab, listing the bus company and schools, with numbered callouts."
    ratio="2072 / 3664"
    items={items}
  />
</HelpLayout>
