---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const startItems = [
  "<strong>Form name</strong> — the form you are about to fill in.",
  "<strong>Description</strong> — when and why to complete this form. Read it; it tells you exactly when the form is required.",
  "<strong>Start</strong> — begin filling in the form.",
];

const sectionItems = [
  "<strong>Section tabs</strong> — the form's sections, in order. A check means the section is complete; swipe or tap to move between them.",
  "<strong>Questions</strong> — the current section's questions. Answer each one; some let you select more than one option.",
  "<strong>Previous and Next</strong> — move between sections.",
];

const reviewItems = [
  "<strong>Incomplete sections</strong> — any section with unanswered required fields is listed here. Tap it to jump back and finish it.",
  "<strong>Report Summary</strong> — every answer you have given, section by section. Double-check it before you submit.",
  "<strong>Submit</strong> — stays greyed out until every required section is complete. Once everything is filled in, tap it to send the form to your organization.",
];

const submittedItems = [
  "<strong>Type filter</strong> — show every submitted form, or only one kind.",
  "<strong>Submitted form</strong> — each form you have sent, with the date and time you submitted it. Tap one to view it.",
];
---

<HelpLayout
  title="Forms"
  description="How forms work in the Veza Mobile App — open a form, move through its sections, and review before you submit."
  back="/support/mobile/"
  wide
>
  <h1>Forms</h1>

  <p class="overview">
    Forms are how you report and submit information to your organization —
    incidents, inspections, hazards and more. Every form works the same way,
    and this guide covers the whole flow: opening a form, moving through its
    sections, required fields, and reviewing before you submit.
  </p>

  <section class="screen">
    <h2 class="screen__title">Opening a form</h2>
    <p class="screen__lead">
      Open the <strong>Resources</strong> tab in the bottom navigation bar and
      tap <strong>Forms</strong>. Your organization's forms are listed there —
      tap one to open it. <strong>Submitted Forms</strong>, at the top of the
      list, holds every form you have already sent.
    </p>
    <div class="pair">
      <figure class="shot">
        <img
          class="phone"
          src="/images/support/mobile/forms/resources-tab.png"
          alt="The Resources tab, with the Forms row highlighted at the top of the list."
          loading="lazy"
        />
        <figcaption>Tap Forms in Resources</figcaption>
      </figure>
      <span class="pair__arrow" aria-hidden="true">→</span>
      <figure class="shot">
        <img
          class="phone"
          src="/images/support/mobile/forms/forms-list.png"
          alt="The Forms screen — a Submitted Forms row on top, then the list of available forms, such as Hazard Form and Pre-Trip Inspection."
          loading="lazy"
        />
        <figcaption>Pick a form from the list</figcaption>
      </figure>
    </div>
  </section>

  <section class="screen">
    <h2 class="screen__title">Starting a form</h2>
    <p class="screen__lead">
      Every form opens on its start screen, which tells you what the form is
      for before you begin.
    </p>
    <Annotated
      src="/images/support/mobile/forms/form-start.png"
      alt="A form's start screen — the Rider Incident Form's name, a description of when it must be completed, and a Start button."
      ratio="2072 / 3664"
      items={startItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Moving through sections</h2>
    <p class="screen__lead">
      A form is split into short sections. The tabs across the top show where
      you are and what is done — move freely; your answers are kept as you go.
    </p>
    <Annotated
      src="/images/support/mobile/forms/form-sections.png"
      alt="A form section asking what you are reporting, with checkbox options, section tabs across the top, and Previous and Next buttons."
      ratio="2072 / 3664"
      items={sectionItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Review and submit</h2>
    <p class="screen__lead">
      The last section is always <strong>Review</strong> — a final check of
      your answers before the form goes to your organization.
    </p>
    <Annotated
      src="/images/support/mobile/forms/form-review.png"
      alt="A form's Review section — a warning listing incomplete sections, a Report Summary of all answers, and a disabled Submit button."
      ratio="2072 / 3664"
      items={reviewItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Submitted forms</h2>
    <p class="screen__lead">
      Everything you submit is kept in <strong>Submitted Forms</strong>, at
      the top of the Forms screen.
    </p>
    <Annotated
      src="/images/support/mobile/forms/submitted-forms.png"
      alt="The Submitted Forms screen — a Type filter set to All forms, and a list of submitted forms with dates and times."
      ratio="2072 / 3664"
      items={submittedItems}
    />
  </section>
</HelpLayout>

<style>
  /* Side-by-side comparison shots on a card matching the annotated shots,
     with an arrow from the first to the second; stacks on small screens. */
  .pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 18px;
    margin: 16px 0 0;
    padding: 22px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .pair__arrow {
    font-size: 1.7rem;
    color: var(--purple);
  }

  .shot {
    margin: 0;
  }

  .shot .phone {
    margin: 0 auto;
  }

  .shot figcaption {
    margin-top: 10px;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .pair {
      grid-template-columns: 1fr;
    }
    .pair__arrow {
      transform: rotate(90deg);
      justify-self: center;
    }
  }
</style>
