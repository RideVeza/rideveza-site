---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const listItems = [
  "<strong>Your children</strong> — everyone you're a guardian for, each on a card with their school. Tap a child to open their profile.",
  "<strong>Icons</strong> — a snapshot of the information on file for your child. See the <a href='/help/guardian/glossary'>icon glossary</a> for what each one means.",
  "<strong>Care &amp; pick-up</strong> — equipment the child uses on the bus, plus reminders like needing a guardian at pick-up.",
];

const profileItems = [
  "<strong>Required staff</strong> — icons showing the staff your child requires on the bus, like an attendant or LPN. See the <a href='/help/guardian/glossary'>icon glossary</a>.",
  "<strong>Name &amp; address</strong> — your child's name and home address.",
  "<strong>Care</strong> — care instructions, medical conditions, equipment, custody and pick-up notes on file for your child, each shown with its icon.",
  "<strong>Contacts</strong> — your child's guardians.",
  "<strong>Emergency contacts</strong> — who the school or driver will call if a guardian can't be reached.",
  "<strong>School</strong> — the school your child attends. Tap it for the school's contact information.",
];
---

<HelpLayout
  title="Your children"
  description="View your children and their details in Veza Guardian."
  back="/help/guardian"
  wide
>
  <h1>Your children</h1>

  <p class="overview">
    The <strong>Children</strong> tab shows everyone you're a guardian for, along
    with their school, care needs and anything the driver should know. Tap a
    child to see their full profile.
  </p>

  <section class="screen">
    <h2 class="screen__title">Children</h2>
    <p class="screen__lead">
      Each child has their own card. Tap one to open their profile.
    </p>
    <Annotated
      src="/images/help/guardian/children-annotated.png"
      alt="The Veza Guardian Children tab, listing each child on a card."
      ratio="2064 / 3664"
      items={listItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Child profile</h2>
    <p class="screen__lead">
      Tapping a child opens their profile — care needs, contacts and more.
    </p>
    <Annotated
      src="/images/help/guardian/child-profile-annotated.png"
      alt="A child's profile in Veza Guardian, showing care, contacts and details."
      ratio="2064 / 3664"
      items={profileItems}
    />
  </section>
</HelpLayout>
