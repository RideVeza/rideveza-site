---
import fs from "node:fs";
import HelpLayout from "../../../layouts/HelpLayout.astro";
import { articles } from "../../../data/mobile-articles.js";

// Build-time guard: every sibling guide page must have a card here, and every
// card must resolve to a guide page or a static page under public/. Throwing
// in frontmatter fails the build, so drift can't ship silently.
const guidePages = new Set(
  Object.keys(import.meta.glob("./*.astro"))
    .map((p) => p.replace("./", "").replace(".astro", ""))
    .filter((s) => s !== "index")
);
const cardSlugs = new Set(
  articles.map((a) => a.href.replace("/support/mobile/", "").replaceAll("/", ""))
);
for (const slug of guidePages) {
  if (!cardSlugs.has(slug)) {
    throw new Error(`Guide /support/mobile/${slug} has no card in src/data/mobile-articles.js`);
  }
}
for (const slug of cardSlugs) {
  if (!guidePages.has(slug) && !fs.existsSync(`public/support/mobile/${slug}/index.html`)) {
    throw new Error(`Card "/support/mobile/${slug}" in src/data/mobile-articles.js has no matching page`);
  }
}
---

<HelpLayout
  title="Mobile App Support"
  description="Guides and support for the Veza Mobile App."
  home="/support/mobile/"
>
  <h1>Veza Guides and Support</h1>
  <span class="eyebrow">Veza Mobile App</span>
  <p class="subtitle">
    Short guides with pictures for the Veza Mobile App. Each one shows what a
    screen does and how to use it. Pick a topic below.
  </p>

  <ul class="card-list">
    {articles.map((a) => (
      <li>
        <a class="topic" href={a.href}>
          <div class="topic-body">
            <h2 class="topic-title">{a.title}</h2>
            <p class="topic-blurb">{a.blurb}</p>
          </div>
          <span class="topic-arrow" aria-hidden="true">→</span>
        </a>
      </li>
    ))}
  </ul>
</HelpLayout>

<style>
  /* Card appearance comes from the shared .topic styles in /veza-ui.css. */
  .card-list {
    list-style: none;
    margin: 28px 0 0;
    padding: 0;
    display: grid;
    gap: 18px;
  }

</style>
