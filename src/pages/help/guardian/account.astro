---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const items = [
  "<strong>Your profile</strong> — your name and initials.",
  "<strong>Email &amp; phone</strong> — the contact details on your account.",
  "<strong>Password &amp; log out</strong> — change your password or log out of the app.",
  "<strong>App Version</strong> — the version you are using. Tell this number to support if you contact them.",
];
---

<HelpLayout
  title="Account"
  description="Manage your details and sign in and out of Veza Guardian."
  back="/help/guardian"
  wide
>
  <h1>Account</h1>

  <p class="overview">
    The <strong>Account</strong> tab is where you manage your own details, and
    sign in or log out.
  </p>

  <Annotated
    src="/images/help/guardian/account-annotated.png"
    alt="The Veza Guardian Account tab, showing profile details and settings, with numbered callouts."
    ratio="2072 / 3664"
    items={items}
  />
</HelpLayout>
