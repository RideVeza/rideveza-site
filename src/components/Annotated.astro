---
// Screenshot with callouts baked in (Figma), beside a matching numbered legend.
const { src, alt, ratio = "2040 / 3600", items = [] } = Astro.props;
---

<div class="annotated">
  <figure class="annotated__shot">
    <img src={src} alt={alt} style={`aspect-ratio:${ratio}`} loading="lazy" />
  </figure>

  <section class="legend">
    <ol class="legend__list">
      {items.map((label, i) => (
        <li>
          <span class="legend__num">{i + 1}</span>
          <span class="legend__text" set:html={label} />
        </li>
      ))}
    </ol>
  </section>
</div>

<style>
  .annotated {
    display: flex;
    align-items: stretch;
    gap: 28px;
    margin: 16px 0 0;
    padding: 22px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .annotated__shot {
    flex: none;
    width: 340px;
    max-width: 100%;
    margin: 0;
  }

  .annotated__shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  .legend {
    flex: 1 1 0;
    min-width: 0;
    padding: 0 0 0 28px;
    border-left: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
  }

  .legend__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 13px;
  }

  .legend__list li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  /* line-height matches the text's first line so the numeral centres on it */
  .legend__num {
    flex: none;
    width: 18px;
    text-align: right;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.6rem;
    color: var(--purple);
    font-variant-numeric: tabular-nums;
  }

  .legend__text { color: var(--ink); }

  @media (max-width: 720px) {
    .annotated {
      flex-direction: column;
      gap: 0;
    }

    .annotated__shot { margin: 0 auto; }

    .legend {
      width: 100%;
      margin-top: 32px;
      padding: 28px 0 0;
      border-left: 0;
      border-top: 1px solid var(--border);
    }
  }
</style>
