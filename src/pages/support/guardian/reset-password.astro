---
import HelpLayout from "../../../layouts/HelpLayout.astro";

---

<HelpLayout
  title="Resetting your password"
  description="Change your Veza Guardian password from the Account tab."
  back="/support/guardian/"
>
  <h1>Resetting your password</h1>

  <p class="overview">
    Forgotten your password, or just want to change it? You can reset it in a few
    steps — start from the Account tab, or from the sign-in screen if you're
    signed out.
  </p>

  <ol class="steps">
    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Open the reset screen</h2>
        <p>
          On the <strong>Account</strong> tab, tap <strong>Change password</strong>.
          Or, if you're signed out, tap <strong>Reset password</strong> on the
          sign-in screen.
        </p>
        <img
          class="phone"
          src="/images/support/guardian/account-screen.png"
          alt="The Account tab, with the Change password option."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Enter your email</h2>
        <p>
          Type the email address you sign in with, then tap
          <strong>Continue</strong>.
        </p>
        <img
          class="phone"
          src="/images/support/guardian/reset-email.png"
          alt="The Reset password screen, asking for your email address."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Enter the verification code</h2>
        <p>
          We email you a 6-digit code. Enter it and tap <strong>Continue</strong>.
          No code? Check your spam folder, or tap
          <strong>Resend verification code</strong>.
        </p>
        <img
          class="phone"
          src="/images/support/guardian/verify-code.png"
          alt="The verification code screen, with six boxes for the code from your email."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Create a new password</h2>
        <p>
          Choose a new password — at least 8 characters, with an uppercase
          letter, a lowercase letter, a number and a special character. Tap
          <strong>Create</strong>, then sign in with your new password.
        </p>
        <img
          class="phone"
          src="/images/support/guardian/create-password.png"
          alt="The Create password screen, listing the password requirements."
          loading="lazy"
        />
      </div>
    </li>
  </ol>
</HelpLayout>
