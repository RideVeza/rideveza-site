---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const checkInItems = [
  "<strong>Step by Step / Summary toggle</strong> — switch between completing the run and reviewing its overview.",
  "<strong>Run banner</strong> — the run's name, vehicle, time window and date.",
  "<strong>Step status</strong> — shows whether the step is still pending or complete.",
  "<strong>Scheduled time</strong> — when this step is scheduled. Once completed, your actual time appears beside it.",
  "<strong>Step card</strong> — the current step, with everything you need to complete it.",
  "<strong>Nearby steps</strong> — the previous and next steps peek in from the edges; swipe to move between them.",
  "<strong>Step action</strong> — complete the step with its button. Here, checking in tells your dispatcher you are awake and prepared for your run.",
  "<strong>Previous and Next</strong> — move between steps.",
];

const stopItems = [
  "<strong>Progress bar</strong> — one pill per step. They fill in as you complete steps, and you can tap a pill to jump to a step.",
  "<strong>Address bar</strong> — the stop's address. Tap it to open the address in your map app.",
  "<strong>Rider card</strong> — a rider at this stop, with their alerts at a glance, such as care needs or a medical condition. See the <a href=\"/support/mobile/glossary\">icon glossary</a> for what each icon means, or tap the card for the <a href=\"/support/mobile/rider-details\">rider's details</a>.",
  "<strong>Picked-up / Absent</strong> — mark each rider as they board, or absent if they are not riding. Tap again to undo.",
  "<strong>Stop information</strong> — notes about the stop from your organization.",
];
---

<HelpLayout
  title="Step by step view"
  description="Complete a run in the Veza Mobile App — check in, inspect, and mark riders picked up or absent."
  back="/support/mobile"
  wide
>
  <h1>Step by step view</h1>

  <p class="overview">
    When you are ready to complete your run, enter the <strong>Step by
    Step</strong> view. It walks you through the run one step at a time — from
    checking in to your final stop — with all the detail you need at each
    step. You can exit this view at any time.
  </p>

  <section class="screen">
    <h2 class="screen__title">One step at a time</h2>
    <p class="screen__lead">
      You start on the first step of your run. A run is a list of steps —
      actions to complete, and stops to visit. The bar at the top shows your
      progress, and you can move between steps at any time.
    </p>
    <Annotated
      src="/images/support/mobile/step-by-step/check-in.png"
      alt="The Step by Step view on the Check In step, with a Check in button and Previous and Next buttons."
      ratio="2072 / 3664"
      items={checkInItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Completing a step</h2>
    <p class="screen__lead">
      Every step is completed with a single tap of its main button. When you
      complete a step, its status becomes a green check, your actual time
      appears beside the scheduled time — green for early or on time, red for
      late — and the step's pill in the progress bar turns white. Made a
      mistake? Tap <strong>Undo</strong> in the card's footer.
    </p>
    <div class="pair">
      <figure class="shot">
        <img
          class="phone"
          src="/images/support/mobile/step-by-step/start-run-pending.png"
          alt="A Start Run step that has not been completed yet, with a Start button and its scheduled time."
          loading="lazy"
        />
        <figcaption>Step not yet completed</figcaption>
      </figure>
      <span class="pair__arrow" aria-hidden="true">→</span>
      <figure class="shot">
        <img
          class="phone"
          src="/images/support/mobile/step-by-step/start-run-completed.png"
          alt="The same Start Run step completed — a green check, the actual time beside the scheduled time, and an Undo option."
          loading="lazy"
        />
        <figcaption>Step completed</figcaption>
      </figure>
    </div>
  </section>

  <section class="screen">
    <h2 class="screen__title">Stops</h2>
    <p class="screen__lead">
      Stops are the addresses you drive to. Each stop lists its riders, and
      everything you need to know about the rider and the stop is on the card.
    </p>
    <Annotated
      src="/images/support/mobile/step-by-step/stop-view.png"
      alt="A stop step listing riders with Picked-up and Absent buttons, the stop address, and stop information."
      ratio="2072 / 3664"
      items={stopItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Finishing the run</h2>
    <p class="screen__lead">
      Once you complete the last step of the run, you are automatically taken
      to the run's <a href="/support/mobile/run-summary">Summary</a> — a recap
      of the completed run, with each step's times and your pay for the run.
    </p>
    <div class="pair">
      <figure class="shot">
        <img
          class="phone"
          src="/images/support/mobile/step-by-step/check-out.png"
          alt="The run's last step, Check Out, completed — the run banner shows a Completed badge."
          loading="lazy"
        />
        <figcaption>Complete the last step</figcaption>
      </figure>
      <span class="pair__arrow" aria-hidden="true">→</span>
      <figure class="shot">
        <img
          class="phone"
          src="/images/support/mobile/step-by-step/run-summary.png"
          alt="The run's Summary screen, showing pay earned from the run and each step's times."
          loading="lazy"
        />
        <figcaption>The run's summary</figcaption>
      </figure>
    </div>
  </section>
</HelpLayout>

<style>
  /* Side-by-side comparison shots on a card matching the annotated shots,
     with an arrow from the first to the second; stacks on small screens. */
  .pair {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 18px;
    margin: 16px 0 0;
    padding: 22px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .pair__arrow {
    font-size: 1.7rem;
    color: var(--purple);
  }

  .shot {
    margin: 0;
  }

  .shot .phone {
    margin: 0 auto;
  }

  .shot figcaption {
    margin-top: 10px;
    text-align: center;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--muted);
  }

  @media (max-width: 560px) {
    .pair {
      grid-template-columns: 1fr;
    }
    .pair__arrow {
      transform: rotate(90deg);
      justify-self: center;
    }
  }
</style>
