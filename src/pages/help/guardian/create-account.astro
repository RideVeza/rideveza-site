---
import HelpLayout from "../../../layouts/HelpLayout.astro";

// Shares the verification-code and create-password screens with the reset flow.
---

<HelpLayout
  title="Creating your account"
  description="Set up your Veza Guardian account."
  back="/help/guardian"
>
  <h1>Creating your account</h1>

  <p class="overview">
    New to Veza Guardian? Create your account with the email address your school
    has for you.
  </p>

  <ol class="steps">
    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Open the app</h2>
        <p>On the welcome screen, tap <strong>Create an account</strong>.</p>
        <img
          class="phone"
          src="/images/help/guardian/splash.png"
          alt="The Veza Guardian welcome screen, with Create an account and Sign in buttons."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Enter your email</h2>
        <p>
          Enter the email address your school has for you, then tap
          <strong>Continue</strong>.
        </p>
        <img
          class="phone"
          src="/images/help/guardian/create-account-email.png"
          alt="The Create an account screen, asking for your email address."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Enter the verification code</h2>
        <p>
          We email you a 6-digit code. Enter it and tap <strong>Continue</strong>.
          No code? Check your spam folder, or tap
          <strong>Resend verification code</strong>.
        </p>
        <img
          class="phone"
          src="/images/help/guardian/verify-code.png"
          alt="The verification code screen, with six boxes for the code from your email."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Create a password</h2>
        <p>
          Choose a password — at least 8 characters, with an uppercase letter, a
          lowercase letter, a number and a special character. Tap
          <strong>Create</strong>.
        </p>
        <img
          class="phone"
          src="/images/help/guardian/create-password.png"
          alt="The Create password screen, listing the password requirements."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Your account is ready</h2>
        <p>
          The app signs you in. It opens on your children's bus runs. If you do
          not see any runs, or no children are listed, contact your school.
        </p>
      </div>
    </li>
  </ol>
</HelpLayout>
