---
import "../styles/help.css";

// back: a URL → shows a back pill instead of the logo. wide: 820px tour pages.
// home: where the brand logo links when there's no back pill.
const { title, description = "", back, backLabel = "‹ Back to all guides", wide = false, home = "/support/guardian" } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>{title} · Veza</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" href="/favicon.svg" />
    <link rel="stylesheet" href="/veza-ui.css" />
  </head>
  <body>
    <div class:list={["wrap", { "wrap--wide": wide }]}>
      <header class="page">
        {back ? (
          <a class="back" href={back}>{backLabel}</a>
        ) : (
          <a class="brand" href={home}>
            <img src="/veza-logo.svg" alt="Veza" />
          </a>
        )}
      </header>

      <main>
        <slot />
      </main>

      <footer class="page">Veza</footer>
    </div>
  </body>
</html>
