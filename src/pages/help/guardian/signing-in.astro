---
import HelpLayout from "../../../layouts/HelpLayout.astro";

---

<HelpLayout
  title="Signing in"
  description="Sign in to the Veza Guardian App."
  back="/help/guardian"
>
  <h1>Signing in</h1>

  <p class="overview">
    Already have an account? Open the Veza Guardian App and sign in with your
    email and password.
  </p>

  <ol class="steps">
    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Open the app</h2>
        <p>On the welcome screen, tap <strong>Sign in</strong>.</p>
        <img
          class="phone"
          src="/images/help/guardian/splash.png"
          alt="The Veza Guardian welcome screen, with Create an account and Sign in buttons."
          loading="lazy"
        />
      </div>
    </li>

    <li class="step">
      <span class="num"></span>
      <div class="body">
        <h2>Enter your email and password</h2>
        <p>
          Type your email and password, then tap <strong>Sign in</strong>.
          Forgotten your password? Tap <strong>Reset password</strong>.
        </p>
        <img
          class="phone"
          src="/images/help/guardian/sign-in.png"
          alt="The Sign in screen, with email and password fields."
          loading="lazy"
        />
      </div>
    </li>
  </ol>

  <div class="note">
    <span class="note__icon" aria-hidden="true">i</span>
    <p>
      <strong>You'll be asked to sign in once a day</strong>, to keep your
      children's information secure. To make it quick, let your phone save your
      password when it offers — then it fills in automatically each time.
    </p>
  </div>
</HelpLayout>
