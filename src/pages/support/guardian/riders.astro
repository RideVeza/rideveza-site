---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const listItems = [
  "<strong>Your riders</strong> — everyone you're a guardian for, each on a card with their school. Tap a rider to open their profile.",
  "<strong>Icons</strong> — a quick view of the information saved for your rider. See the <a href='/support/guardian/glossary'>icon glossary</a> for what each icon means.",
  "<strong>Care and guardian needs</strong> — equipment the rider uses on the bus, and reminders such as needing a guardian at drop-off.",
];

const profileItems = [
  "<strong>Required staff</strong> — icons showing the staff your rider requires on the bus, like an attendant or LPN. See the <a href='/support/guardian/glossary'>icon glossary</a>.",
  "<strong>Name &amp; address</strong> — your rider's name and home address.",
  "<strong>Care</strong> — care instructions, medical conditions, equipment, custody and pick-up notes saved for your rider, each shown with its icon.",
  "<strong>Contacts</strong> — your rider's guardians.",
  "<strong>Emergency contacts</strong> — who the school or driver will call if a guardian can't be reached.",
  "<strong>School</strong> — the school your rider attends. Tap it for the school's contact information.",
];
---

<HelpLayout
  title="Your riders"
  description="View your riders and their details in Veza Guardian."
  back="/support/guardian/"
  wide
>
  <h1>Your riders</h1>

  <p class="overview">
    The <strong>Riders</strong> tab shows every rider you are a guardian for.
    Each rider shows their school, care needs, and notes for the driver. Tap a
    rider to see their full profile.
  </p>

  <section class="screen">
    <h2 class="screen__title">Riders</h2>
    <p class="screen__lead">
      Each rider has their own card. Tap one to open their profile.
    </p>
    <Annotated
      src="/images/support/guardian/riders-annotated.png"
      alt="The Veza Guardian Riders tab, listing each rider on a card, with numbered callouts."
      ratio="2064 / 3664"
      items={listItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Rider profile</h2>
    <p class="screen__lead">
      Tapping a rider opens their profile — care needs, contacts and more.
    </p>
    <Annotated
      src="/images/support/guardian/rider-profile-annotated.png"
      alt="A rider's profile in Veza Guardian, showing care, contacts and details, with numbered callouts."
      ratio="2064 / 3664"
      items={profileItems}
    />
  </section>
</HelpLayout>
