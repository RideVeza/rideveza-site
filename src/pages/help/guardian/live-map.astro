---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const homeItems = [
  "<strong>A run</strong> — tap any run to open it on the live map. This is how you start tracking the bus.",
  "<strong>Run name</strong> — the run's ID and its direction, such as \"Run to School\" or \"Run Home\".",
  "<strong>Children</strong> — who's travelling on this run.",
  "<strong>Time &amp; stop</strong> — your child's address and the scheduled time the bus will arrive.",
  "<strong>Status</strong> — whether the run is completed, in progress, or still to come.",
  "<strong>View all</strong> — see your full list of upcoming runs.",
  "<strong>Future runs</strong> — a preview of the next three runs.",
  "<strong>Menu</strong> — move between Runs, Children, Contacts and Account.",
];

const mapItems = [
  "<strong>Run ID</strong> — the ID of the run you're following.",
  "<strong>Run status</strong> — the run's current status and the estimated arrival time at your stop.",
  "<strong>Bus last seen</strong> — the last time the bus sent its location. If it's a few minutes old, the bus is simply between updates.",
  "<strong>Map controls</strong> — find the bus, change to satellite mode or zoom out to see everything.",
  "<strong>School</strong> — your child's school on the map, where the run drops off or picks up.",
  "<strong>The bus</strong> — its live position on the map. The icon moves as the bus drives.",
  "<strong>Your stop</strong> — the home pin marks where your child is picked up or dropped off.",
  "<strong>Map / Details</strong> — switch between the live map and the run details.",
];

const detailsItems = [
  "<strong>Latest update</strong> — the actual completion time for pick-up or drop-off at your child's stop.",
  "<strong>Run status</strong> — whether the run is still in progress or has finished.",
  "<strong>Children on the run</strong> — everyone travelling, with the time each was picked up or dropped off.",
  "<strong>Status</strong> — a badge showing whether each child is on board or has been dropped off.",
  "<strong>Scheduled time</strong> — when the bus is planned to reach each stop.",
  "<strong>Completed time</strong> — when the bus actually got there.",
  "<strong>Team members</strong> (scroll down - not pictured) — tap to see the driver and any other staff on the bus.",
  "<strong>Bus</strong> (scroll down - not pictured) — the vehicle number for this run.",
];
---

<HelpLayout
  title="Tracking the bus"
  description="How to follow your child's bus on the live map in Veza Guardian."
  back="/help/guardian"
  wide
>
  <h1>Tracking the bus</h1>

  <p class="overview">
    Veza Guardian lets you follow your child's bus — see where it is, when it'll
    reach your stop, and who's on board. Each trip the bus makes is called a
    <strong>run</strong>. Here's how to find one and what each screen shows.
  </p>

  <section class="screen">
    <h2 class="screen__title">Today's runs</h2>
    <p class="screen__lead">
      The Runs tab lists today's runs and what's coming up. Tap a run to open it
      on the map.
    </p>
    <Annotated
      src="/images/help/guardian/home-annotated.png"
      alt="The Veza Guardian Runs tab, with numbered callouts pointing to each feature."
      ratio="2072 / 3664"
      items={homeItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Map</h2>
    <p class="screen__lead">
      Tapping a run opens it here — a live map of where the bus is right now and
      when it's due at your stop. Tap <strong>Details</strong> at the bottom for
      the rest of the run.
    </p>
    <Annotated
      src="/images/help/guardian/live-map-annotated.png"
      alt="The Veza Guardian live map screen, with numbered callouts pointing to each feature."
      ratio="2064 / 3664"
      items={mapItems}
    />
  </section>

  <section class="screen">
    <h2 class="screen__title">Details</h2>
    <p class="screen__lead">
      Details slides up over the map with the full picture of the run. Tap
      <strong>Map</strong> at the bottom to go back to tracking.
    </p>
    <Annotated
      src="/images/help/guardian/details-annotated.png"
      alt="The Veza Guardian run details panel, with numbered callouts pointing to each feature."
      ratio="2068 / 3700"
      items={detailsItems}
    />
  </section>
</HelpLayout>
