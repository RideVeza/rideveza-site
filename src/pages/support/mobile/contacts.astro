---
import HelpLayout from "../../../layouts/HelpLayout.astro";
---

<HelpLayout
  title="Contacts"
  description="Find contact information for your organization in the Veza Mobile App."
  back="/support/mobile"
>
  <h1>Contacts</h1>

  <p class="overview">
    Open the <strong>Contacts</strong> tab in the bottom navigation bar to find
    the right person at your organization — dispatch, safety, your supervisor
    and more.
  </p>

  <p>
    Tap any contact to open a pop-up with their phone number and email.
  </p>

  <img
    class="phone"
    src="/images/support/mobile/contacts/contacts.png"
    alt="The Veza Mobile App Contacts screen, listing contacts such as Dispatch, Fleet and Safety."
    loading="lazy"
  />

  <div class="note">
    <span class="note__icon" aria-hidden="true">i</span>
    <p>
      In the event of a <strong>serious emergency, call 911</strong>
      immediately, followed by Dispatch.
    </p>
  </div>
</HelpLayout>

<style>
  .phone {
    margin: 24px 0 32px;
  }
</style>
