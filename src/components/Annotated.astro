---
/*
 * Annotated — a pre-numbered screenshot beside a matching numbered legend.
 *
 * The numbers and connector lines are baked into the image (designed in Figma),
 * so this component just displays it and renders the legend whose numbers line
 * up with the ones on the screen. Legend copy stays as editable HTML text.
 *
 * The legend uses plain numerals (not filled circles) so it reads as a list
 * reference and stays visually distinct from the purple anchor circles on the
 * image. A thin divider separates the two columns.
 *
 * Layout: image left, descriptions right on wider screens; stacks on mobile.
 *
 * Props:
 *  - src, alt:  the annotated screenshot
 *  - ratio:     "w / h" of the source image (avoids layout shift)
 *  - items:     [string]  legend lines, in number order (HTML allowed, e.g. <strong>)
 */
const { src, alt, ratio = "2040 / 3600", items = [] } = Astro.props;
---

<div class="annotated">
  <figure class="annotated__shot">
    <img src={src} alt={alt} style={`aspect-ratio:${ratio}`} loading="lazy" />
  </figure>

  <section class="legend">
    <ol class="legend__list">
      {items.map((label, i) => (
        <li>
          <span class="legend__num">{i + 1}</span>
          <span class="legend__text" set:html={label} />
        </li>
      ))}
    </ol>
  </section>
</div>

<style>
  .annotated {
    display: flex;
    align-items: stretch;
    gap: 28px;
    margin: 16px 0 0;
  }

  .annotated__shot {
    flex: none;
    width: 340px;
    max-width: 100%;
    margin: 0;
  }

  .annotated__shot img {
    display: block;
    width: 100%;
    height: auto;
  }

  /* ---- Legend: beside the screenshot, behind a thin divider ---- */
  .legend {
    flex: 1 1 0;
    min-width: 0;
    padding: 0 0 0 28px;
    border-left: 1px solid var(--border);
    display: flex;
    align-items: flex-start;
  }

  .legend__list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 13px;
  }

  .legend__list li {
    display: flex;
    gap: 12px;
    align-items: flex-start;
  }

  /* Plain purple numeral — light footprint, distinct from the image circles.
     line-height matches the text's first-line box (1rem * 1.6) so the numeral
     centers against the bold step text rather than sitting on its baseline. */
  .legend__num {
    flex: none;
    width: 18px;
    text-align: right;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 0.95rem;
    line-height: 1.6rem;
    color: var(--purple);
    font-variant-numeric: tabular-nums;
  }

  .legend__text { color: var(--ink); }
  .legend__text strong { color: var(--navy); font-weight: 600; }

  /* ---- Narrow screens: stack the legend under the screenshot ---- */
  @media (max-width: 720px) {
    .annotated {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .annotated__shot { margin: 0 auto; }

    .legend {
      width: 100%;
      margin-top: 32px;
      padding: 28px 0 0;
      border-left: 0;
      border-top: 1px solid var(--border);
    }
  }
</style>
