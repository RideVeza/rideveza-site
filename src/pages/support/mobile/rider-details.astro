---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const items = [
  "<strong>Name and address</strong> — the rider, and the address of their stop.",
  "<strong>Alerts</strong> — the rider's alerts, such as care needs or a medical condition. See the <a href=\"/support/mobile/glossary\">icon glossary</a> for what each icon means, or tap the row for the rider's care plan.",
  "<strong>Care note</strong> — what the rider needs on the bus, such as equipment or medication.",
  "<strong>Contacts</strong> — the rider's guardians. Tap a contact for their details, including their phone number.",
  "<strong>Primary</strong> — marks the rider's primary contact.",
  "<strong>Emergency contacts</strong> — who to reach if the rider's contacts cannot be reached.",
];
---

<HelpLayout
  title="Rider details"
  description="View a rider's profile in the Veza Mobile App."
  back="/support/mobile"
  wide
>
  <h1>Rider details</h1>

  <p class="overview">
    Tap any rider on a run to open their profile — their care needs, contacts
    and key safety information, so you can support each rider safely.
  </p>

  <Annotated
    src="/images/support/mobile/rider-details/rider-details-annotated.png"
    alt="A rider's profile, with numbered callouts pointing to the rider's care information and contacts."
    ratio="2060 / 3664"
    items={items}
  />
</HelpLayout>
