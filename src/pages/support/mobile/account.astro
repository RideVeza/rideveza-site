---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const items = [
  "<strong>Your details</strong> — your name, job title, company and employee ID, as your organization has them on file.",
  "<strong>Default map</strong> — choose the map app that opens when you navigate. Veza supports Apple Maps, Google Maps and Waze.",
  "<strong>App version</strong> — the version of the app you are running. Helpful when reporting a problem.",
  "<strong>Log out</strong> — securely log out of your account.",
];
---

<HelpLayout
  title="Account settings"
  description="Manage your profile in the Veza Mobile App."
  back="/support/mobile/"
  wide
>
  <h1>Account settings</h1>

  <p class="overview">
    Open the <strong>Account</strong> tab in the bottom navigation bar to see
    your profile information, choose your preferred map app, and log out.
  </p>

  <Annotated
    src="/images/support/mobile/account/account-annotated.png"
    alt="The Veza Mobile App Account screen, with numbered callouts pointing to each feature."
    ratio="2072 / 3664"
    items={items}
  />
</HelpLayout>
