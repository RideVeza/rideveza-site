---
import HelpLayout from "../../../layouts/HelpLayout.astro";

// Icon tiles are shared with the guardian glossary exports (pre-styled PNGs).
const entries = [
  {
    icon: "icon-driver.png",
    title: "Driver",
    desc: "Represents a driver. Used to distinguish this role in the team section of a run.",
  },
  {
    icon: "icon-attendant.png",
    title: "Attendant",
    desc: "Represents an attendant. Used to distinguish this role in the team section of a run and to show that an attendant is present on the run.",
  },
  {
    icon: "icon-lpn.png",
    title: "LPN",
    desc: "Represents an LPN (licensed practical nurse). Used to distinguish this role in the team section of a run and to show that an LPN is present on the run.",
  },
  {
    icon: "icon-care.png",
    title: "Care",
    desc: "Appears on rider profiles and indicates that care instructions are provided (a care plan).",
  },
  {
    icon: "icon-equipment.png",
    title: "Equipment",
    desc: "Appears on rider profiles and indicates that they have equipment requirements.",
  },
  {
    icon: "icon-medical.png",
    title: "Medical",
    desc: "Appears on rider profiles and indicates that they have a medical condition.",
  },
  {
    icon: "icon-met-at-bus.png",
    title: "Met at the bus",
    desc: "Appears on rider profiles and indicates that they must be met at the bus at their stop.",
  },
  {
    icon: "icon-custody.png",
    title: "Custody",
    desc: "Appears on rider profiles and indicates that they have a custody consideration.",
  },
  {
    icon: "icon-support-staff.png",
    title: "Support staff",
    desc: "Appears on rider profiles and indicates that the rider requires the presence of an attendant or an LPN (or both) on the bus.",
    wide: true,
  },
];
---

<HelpLayout
  title="Icon glossary"
  description="What each icon in the Veza Mobile App means."
  back="/support/mobile"
>
  <h1>Icon glossary</h1>

  <p class="overview">
    Veza uses a variety of icons to help you navigate the app. Here is a guide
    to their meanings.
  </p>

  <ul class="glossary">
    {entries.map((e) => (
      <li class="entry">
        <span class="entry__icon">
          <img
            src={`/images/support/guardian/icons/${e.icon}`}
            alt=""
            width={e.wide ? 109 : 60}
            height="60"
            loading="lazy"
          />
        </span>
        <div class="entry__text">
          <h2 class="entry__title">{e.title}</h2>
          <p class="entry__desc">{e.desc}</p>
        </div>
      </li>
    ))}
  </ul>
</HelpLayout>

<style>
  /* Same reference-list card as the guardian glossary. */
  .glossary {
    list-style: none;
    margin: 0;
    padding: 0 22px;
    background: var(--card-bg);
    border: 1px solid var(--border);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-soft);
  }

  .entry {
    display: flex;
    align-items: center;
    gap: 32px;
    padding: 22px 0;
    border-bottom: 1px solid var(--border);
  }

  .entry:last-child {
    border-bottom: none;
  }

  .entry__icon {
    flex: none;
    width: 120px;
    display: flex;
    align-items: center;
  }

  .entry__icon img {
    display: block;
    height: 60px;
    width: auto;
  }

  .entry__text {
    flex: 1 1 auto;
    min-width: 0;
  }

  .entry__title {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: var(--navy);
    margin: 0 0 4px;
  }

  .entry__desc {
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
  }

  @media (max-width: 480px) {
    .glossary {
      padding: 0 16px;
    }
    .entry {
      gap: 16px;
      padding: 20px 0;
    }
    .entry__icon {
      width: 112px;
    }
  }
</style>
