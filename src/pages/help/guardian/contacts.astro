---
import HelpLayout from "../../../layouts/HelpLayout.astro";
import Annotated from "../../../components/Annotated.astro";

const items = [
  "<strong>Transportation</strong> — your children's bussing company. Tap to find contact information.",
  "<strong>Schools</strong> — your children's schools. Tap to find contact information.",
];
---

<HelpLayout
  title="Contacts"
  description="The phone numbers you might need in Veza Guardian."
  back="/help/guardian"
  wide
>
  <h1>Contacts</h1>

  <p class="overview">
    The <strong>Contacts</strong> tab keeps the contact details you might need
    in one place — your children's bussing company and their schools.
  </p>

  <Annotated
    src="/images/help/guardian/contacts-annotated.png"
    alt="The Veza Guardian Contacts tab, listing transportation companies and schools."
    ratio="2072 / 3664"
    items={items}
  />
</HelpLayout>
