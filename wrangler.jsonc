{
  // Static-assets deployment for Cloudflare Workers.
  // The Astro site is pure static output (no SSR adapter); `wrangler deploy`
  // just uploads the built ./dist directory to Cloudflare's CDN.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "rideveza-site",
  "compatibility_date": "2026-06-22",
  "assets": {
    "directory": "./dist"
  }
}
